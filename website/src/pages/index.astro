---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import Hero from '../components/Hero.astro'
import SocialProof from '../components/SocialProof.astro'
import Features from '../components/Features.astro'
import HowItWorks from '../components/HowItWorks.astro'
import PricingTable from '../components/PricingTable.jsx'
import FAQ from '../components/FAQ.jsx'

const title = 'ReplyPals — Write better. Reply faster.'
const description = 'ReplyPals rewrites your emails, messages and posts in seconds. Chrome extension for non-native English speakers.'
const canonicalUrl = 'https://replypals.in/'
---

<BaseLayout title={title} description={description} canonicalUrl={canonicalUrl}>
  <Header />
  <main>
    <Hero />
    <SocialProof />
    <Features />
    <HowItWorks />
    <PricingTable client:load />
    <FAQ client:load />
  </main>
  <Footer />
</BaseLayout>
