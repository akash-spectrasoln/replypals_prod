---
const chromeUrl = 'https://chrome.google.com/webstore/detail/replypals/jipgphhkpgkjjfpjbjjnbdikjkgmnnkp'
---

<section class="border-b border-slate-200 bg-gradient-to-b from-indigo-50 to-white py-16 md:py-24">
  <div class="mx-auto grid max-w-6xl items-center gap-10 px-4 md:grid-cols-2">
    <div>
      <h1 class="text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">
        Write better. Reply faster. Sound like a native.
      </h1>
      <p class="mt-4 text-lg text-slate-600">
        ReplyPals rewrites your emails, messages and posts in seconds
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href={chromeUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex rounded-xl bg-indigo-600 px-6 py-3 font-semibold text-white shadow-sm hover:bg-indigo-700"
        >
          Add to Chrome — It&apos;s Free
        </a>
        <a
          href="#how-it-works"
          class="inline-flex items-center rounded-xl border border-slate-300 bg-white px-6 py-3 font-semibold text-slate-800 hover:bg-slate-50"
        >
          See how it works
        </a>
      </div>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-lg">
      <div class="aspect-video rounded-lg bg-gradient-to-br from-indigo-100 to-slate-100 p-6">
        <p class="text-sm font-medium text-indigo-900">Extension preview</p>
        <p class="mt-2 text-sm text-slate-600">
          Select text &rarr; choose tone &rarr; get polished English in one click.
        </p>
        <div class="mt-4 rounded-md bg-white p-3 text-xs text-slate-700 shadow-inner">
          &ldquo;Thanks for your patience — here&apos;s the updated draft.&rdquo;
        </div>
      </div>
    </div>
  </div>
</section>
